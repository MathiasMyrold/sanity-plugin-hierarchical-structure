{
  "name": "sanity-plugin-hierarchical-structure",
  "version": "1.0.0",
  "description": "A Sanity Studio plugin for displaying documents in hierarchical accordion structures with forward and reverse relationships",
  "keywords": [
    "sanity",
    "sanity-plugin",
    "hierarchical",
    "structure",
    "accordion",
    "tree-view"
  ],
  "homepage": "https://github.com/MathiasMyrold/sanity-plugin-hierarchical-structure#readme",
  "bugs": {
    "url": "https://github.com/MathiasMyrold/sanity-plugin-hierarchical-structure/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MathiasMyrold/sanity-plugin-hierarchical-structure.git"
  },
  "license": "MIT",
  "type": "module",
  "author": "Your Name <your.email@example.com>",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.esm.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.esm.d.ts",
  "sideEffects": false,
  "browserslist": "extends @sanity/browserslist-config",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "plugin-kit verify-package --silent && pkg-utils build --strict --check --clean",
    "link-watch": "plugin-kit link-watch",
    "lint": "eslint .",
    "prepublishOnly": "npm run build",
    "watch": "pkg-utils watch --strict"
  },
  "dependencies": {
    "@sanity/icons": "^3.0.0",
    "@sanity/incompatible-plugin": "^1.0.4",
    "@sanity/ui": "^2.0.0 || ^3.0.0"
  },
  "devDependencies": {
    "@sanity/browserslist-config": "^1.0.5",
    "@sanity/pkg-utils": "^6.0.0",
    "@sanity/plugin-kit": "^4.0.0",
    "@types/react": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-sanity": "^7.0.0",
    "react": "^19.0.0",
    "sanity": "^3.0.0 || ^5.0.0",
    "typescript": "^5.1.6"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "sanity": "^3.0.0 || ^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "sanityPlugin": {
    "verifyPackage": {
      "sanityV2Json": false,
      "eslintImports": false
    }
  }
}
